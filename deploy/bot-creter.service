[Unit]
Description=Bot Creter — Telegram bot factory
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=REPLACE_WITH_SERVER_USER
WorkingDirectory=/REPLACE/PATH/TO/bot-creter
EnvironmentFile=/REPLACE/PATH/TO/bot-creter/.env
ExecStart=/REPLACE/PATH/TO/bot-creter/venv/bin/python main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
