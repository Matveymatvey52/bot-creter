BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Опционально — без него голосовые сообщения не распознаются
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Telegram ID владельца — единственный, кто видит админ-команды фабрики (/admin и т.п.)
OWNER_ID=your_telegram_user_id_here

# Ключ шифрования токенов ботов в БД (Fernet, cryptography). Сгенерировать:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Путь к персистентным данным (БД, сгенерированные боты, картинки).
# По умолчанию (если не задать) — папка data/ рядом с самим проектом,
# независимо от рабочей директории процесса. На VDS диск персистентный
# по умолчанию — трогать не нужно. Раскомментируй и укажи свой путь только
# если нужно вынести данные за пределы репозитория.
# DATA_DIR=/absolute/path/to/data
